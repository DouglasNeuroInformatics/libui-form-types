    "@douglasneuroinformatics/semantic-release": "^0.2.1",
    "@douglasneuroinformatics/tsconfig": "^2.0.0",
    "@types/lodash": "^4.17.5",
    "concurrently": "^8.2.2",
    "eslint": "^9.20.1",
    "expect-type": "^0.19.0",
    "http-server": "^14.1.1",
    "husky": "^9.0.11",
    "lodash": "^4.17.21",
    "prettier": "^3.5.0",
    "typedoc": "^0.26.1",
    "typescript": "6.0.x"
  },
  "commitlint": {
    "extends": [
      "@douglasneuroinformatics/semantic-release/commitlint-config"
